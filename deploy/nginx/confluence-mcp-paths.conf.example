# Add these location blocks into the existing Azure DevOps MCP nginx server
# definitions so that /mcp and /health keep routing to Azure DevOps MCP while
# /confluence/* routes to this Confluence MCP backend.

location /confluence/mcp {
    proxy_pass http://confluence-mcp-server:3000/mcp;
    proxy_http_version 1.1;

    proxy_set_header Host $http_host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header Authorization $http_authorization;
    proxy_set_header X-API-Key $http_x_api_key;
    proxy_set_header X-Confluence-Authorization $http_x_confluence_authorization;
    proxy_set_header X-Confluence-Email $http_x_confluence_email;
    proxy_set_header X-Confluence-Api-Token $http_x_confluence_api_token;
    proxy_set_header X-Confluence-Base-Url $http_x_confluence_base_url;
    proxy_set_header Connection "";

    proxy_buffering off;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
    chunked_transfer_encoding on;
}

location /confluence/health {
    proxy_pass http://confluence-mcp-server:3000/health;
    proxy_set_header Host $http_host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Real-IP $remote_addr;
}

location /confluence/ready {
    proxy_pass http://confluence-mcp-server:3000/ready;
    proxy_set_header Host $http_host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Real-IP $remote_addr;
}

# Optional internal endpoints. Keep them protected with MCP API key auth if you expose them.
location /confluence/metrics {
    proxy_pass http://confluence-mcp-server:3000/metrics;
    proxy_set_header Host $http_host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header Authorization $http_authorization;
    proxy_set_header X-API-Key $http_x_api_key;
}

location /confluence/sync-status {
    proxy_pass http://confluence-mcp-server:3000/sync-status;
    proxy_set_header Host $http_host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header Authorization $http_authorization;
    proxy_set_header X-API-Key $http_x_api_key;
}
